prefer-no-csd

output "DP-1" {
    mode "2560x1440@164.999"
    position x=1080 y=480
    focus-at-startup
}

output "DP-2" {
    mode "1920x1080"
    position x=0 y=0
    transform "270"
    layout {
        gaps 6
        default-column-width { proportion 1.0; }
        struts {
            top 4
            bottom 4
            left 4
            right 4
        }
    }
}

animations {
    window-open {
        duration-ms 150
        curve "ease-out-expo"
    }

    window-close {
        off
        // duration-ms 150
        // curve "ease-out-quad"
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    workspace-switch {
        spring damping-ratio=2.0 stiffness=2000 epsilon=0.0001
    }

    window-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    window-resize {
        // off
        spring damping-ratio=1.0 stiffness=2000 epsilon=0.0001
    }

    config-notification-open-close {
        off
    }

    exit-confirmation-open-close {
        off
    }

    screenshot-ui-open {
        duration-ms 100
        curve "ease-out-quad"
    }

    overview-open-close {
        spring damping-ratio=1.0 stiffness=2000 epsilon=0.0001
    }

    recent-windows-close {
        off
    }
}

hotkey-overlay {
    skip-at-startup
}

environment {
  CLUTTER_BACKEND "wayland"
  GDK_BACKEND "wayland,x11,*"
  GDK_DPI_SCALE "1"
  GDK_SCALE "1"
  QT_AUTO_SCREEN_SCALE_FACTOR "1"
  QT_QPA_PLATFORM "wayland;xcb"
  QT_QPA_PLATFORMTHEME "qt6ct"
  QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
  SDL_VIDEODRIVER "wayland"
  GSK_RENDERER "ngl"
  ELECTRON_OZONE_PLATFORM_HINT "auto"
  WLR_NO_HARDWARE_CURSORS "1"
  DMS_DISABLE_MATUGEN "1"
  QT_MEDIA_BACKEND "ffmpeg"
}

screenshot-path "~/Pictures/Screenshots/screenshot-%Y-%m-%d_%H-%M-%S.png"


gestures {
    dnd-edge-view-scroll {
        trigger-width 100
        delay-ms 100
        max-speed 3500
    }

    dnd-edge-workspace-switch {
        trigger-height 50
        delay-ms 100
        max-speed 3500
    }

    hot-corners {
        top-right
    }
}

input {
    // focus-follows-mouse
    focus-follows-mouse max-scroll-amount="0%"
    keyboard {
        repeat-delay 200
        repeat-rate 50
        xkb {
            layout "us"
            options "compose:caps"
        }
        numlock
    }
    mouse {
        accel-speed 0.2
        accel-profile "flat"
    }
    mod-key "Super"
}


layout {
    gaps 10
    default-column-width { proportion 1.0; }
    always-center-single-column
    empty-workspace-above-first

    preset-column-widths {
        proportion 0.50
        proportion 1.0
    }

    struts {
        left 16
        right 16
    }

    focus-ring {
        on
        active-gradient from="#80c8ff" to="rgba(0,0,0,0)" angle=135
        inactive-color "rgba(0,0,0,0)"
    }

    shadow {
        on
        draw-behind-window false
        softness 40
        spread 5
        offset x=0 y=5
        color "#0007"
    }

}

blur {
    // off
    passes 2
    offset 2
    noise 0.02
    saturation 0.8
}

overview {
    backdrop-color "#1a1b26"
    zoom 0.45
    workspace-shadow {
        softness 50
        spread 20
        offset x=0 y=10
        color "#0007"
    }
}

workspace "code"{
    open-on-output "DP-1"
}
workspace "games"{
    open-on-output "DP-1"
}

workspace "media"{
    open-on-output "DP-2"
}
workspace "web"{
    open-on-output "DP-2"
}
workspace "ai" {
    open-on-output "DP-2"
}

spawn-sh-at-startup "niri_helper -s DP-2"


spawn-at-startup "xdg-desktop-portal-gnome"
spawn-at-startup "blueman-applet"

spawn-at-startup "thunar" "--daemon"
spawn-at-startup "elephant"
spawn-at-startup "openrgb" "-p" "Default"
spawn-at-startup "xwayland-satellite"
spawn-at-startup "qs" "-c" "noctalia-shell"

// spawn-at-startup "mako"
// spawn-at-startup "waybar" "-c" "/home/nomig/.config/waybar/config-main.jsonc"
// spawn-at-startup "waybar" "-c" "/home/nomig/.config/waybar/config-second.jsonc"
// spawn-at-startup "walker" "--gapplication-service"
// spawn-sh-at-startup "swaybg -o DP-1 -i ~/Pictures/wallpapers/.wallpaper_DP-1 -m fill"
// spawn-sh-at-startup "swaybg -o DP-2 -i ~/Pictures/wallpapers/.wallpaper_DP-2 -m fill"


spawn-at-startup "ghostty"
spawn-at-startup "firefox"
spawn-at-startup "steam"
spawn-at-startup "chromium" "--app=https://web.whatsapp.com"
spawn-at-startup "youtube-music"
spawn-at-startup "chromium" "--app=https://chatgpt.com"

include "window_rules.kdl"
include "keybinds.kdl"
