#!/bin/bash
set -euo pipefail

wallpaper_dir="$HOME/Pictures/wallpapers"
themes_dir="$HOME/.config/rofi/themes"

# Get monitors (focused monitor first = primary)
mapfile -t MONITORS < <(
  hyprctl monitors -j | jq -r 'sort_by(.id) | .[].name'
)

idx="${1:-0}"
monitor="${MONITORS[$idx]:-}"

[[ -z "$monitor" ]] && {
  echo "Invalid monitor index: $idx"
  exit 1
}

output_image="$wallpaper_dir/.wallpaper_${monitor}"

# Transition config (unused unless swww later)
FPS=60
TYPE="any"
DURATION=3
BEZIER="0.4,0.2,0.4,1.0"

# Get wallpapers
mapfile -t PICS < <(
  find "$wallpaper_dir" -maxdepth 1 -type f \
    \( -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" -o -iname "*.gif" \) \
    | sort
)

[[ ${#PICS[@]} -eq 0 ]] && {
  echo "No images found in $wallpaper_dir"
  exit 1
}

# Random choice
randomNumber=$(( ($(date +%s) + RANDOM) + $$ ))
randomPicture="${PICS[$(( randomNumber % ${#PICS[@]} ))]}"
randomChoice="[${#PICS[@]}] Random"

menu() {
  printf "%s\n" "$randomChoice"
  for img in "${PICS[@]}"; do
    if [[ ! "$img" =~ \.gif$ ]]; then
      printf "%s\x00icon\x1f%s\n" \
        "$(basename "$img" | cut -d. -f1)" "$img"
    else
      printf "%s\n" "$(basename "$img")"
    fi
  done
}

choice=$(menu | rofi -i -dmenu -theme "${themes_dir}/wallpaper-select.rasi")
[[ -z "$choice" ]] && exit 0

if [[ "$choice" = "$randomChoice" ]]; then
  selected="$randomPicture"
else
  for img in "${PICS[@]}"; do
    name=$(basename "$img" | cut -d. -f1)
    [[ "$choice" == "$name" ]] && selected="$img" && break
  done
fi

[[ -z "${selected:-}" ]] && {
  echo "Image not found."
  exit 1
}

mkdir -p "$wallpaper_dir"
rm -f "$output_image"
cp "$selected" "$output_image"

hyprctl hyprpaper wallpaper "$monitor,$output_image"

